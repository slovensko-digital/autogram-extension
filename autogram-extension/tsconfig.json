{
  "compilerOptions": {
    "jsx": "react",
    "outDir": "./dist/",
    "moduleResolution": "bundler",
    // "noImplicitAny": false,
    "allowSyntheticDefaultImports": true, // because of webpack config
    "esModuleInterop": true, // because of webpack config
    "sourceMap": true,
    "strictNullChecks": true,
    "module": "ESNext",
    "target": "ES5",
    "allowJs": true,
    "experimentalDecorators": true,
    "lib": ["ES5", "ES2023", "DOM", "ESNext"],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "paths": {
      "autogram-sdk": ["../autogram-sdk/src"],
      "autogram-sdk/*": ["../autogram-sdk/src/*"]
    }
  },
  "include": ["src/**/*", "webpack/**/*"],
  // webpack-build/webpack-watch are the legacy build path; they depend on
  // webpack-merge which is no longer installed
  "exclude": ["spec", "webpack/webpack-build.ts", "webpack/webpack-watch.ts"],
  "ts-node": {
      "esm": true
  }
}
