{
  "name": "autogram-extension-monorepo",
  "version": "4.0.0",
  "private": true,
  "description": "Monorepo for Autogram Extension",
  "workspaces": [
    "autogram-sdk",
    "autogram-extension"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "watch:mv2": "run-s sdk:build watch:mv2:_parallel",
    "watch:mv2:_parallel": "run-p \"ext:start:mv2\" \"sdk:build:watch\"",
    "watch:mv3": "run-s sdk:build watch:mv3:_parallel",
    "watch:mv3:_parallel": "run-p \"ext:start:mv3\" \"sdk:build:watch\"",
    "sdk:build:watch": "npm run build:watch -w autogram-sdk",
    "sdk:build": "npm run build -w autogram-sdk",
    "ext:build": "npm run build:prod -w autogram-extension",
    "ext:build:dev": "npm run build:dev -w autogram-extension",
    "ext:start:mv2": "npm run start:mv2 -w autogram-extension",
    "ext:start:mv3": "npm run start:mv3 -w autogram-extension",
    "example-extension-usage": "cd example-extension-usage && vite --port 49675",
    "example-avm-integration": "cd example-avm-integration && vite --port 49676",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "start": "echo 'Please specify which extension manifest version to start: npm run watch:mv2 or npm run watch:mv3'",
    "postinstall": "npm run sdk:build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slovensko-digital/autogram-extension.git"
  },
  "keywords": [
    "autogram",
    "slovensko.digital",
    "slovensko",
    "upvs",
    "slovensko.sk",
    "eidas",
    "eID",
    "electronic",
    "signature",
    "PAdES",
    "XAdE"
  ],
  "author": "pomali",
  "license": "EUPL-1.2",
  "bugs": {
    "url": "https://github.com/slovensko-digital/autogram-extension/issues"
  },
  "homepage": "https://github.com/slovensko-digital/autogram-extension#readme",
  "dependencies": {
    "crypto-browserify": "^3.12.0",
    "idb-keyval": "^6.2.1",
    "js-base64": "^3.7.7",
    "loglevel": "^1.9.2",
    "loglevel-plugin-prefix": "^0.8.4",
    "stream-browserify": "^3.0.0",
    "vm-browserify": "^1.1.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "buffer": "^6.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "openapi-typescript": "^6.7.4",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^6.4.2"
  }
}
