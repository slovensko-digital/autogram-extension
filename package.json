{
  "name": "autogram-extension-monorepo",
  "version": "4.0.0",
  "private": true,
  "description": "Monorepo for Autogram Extension",
  "workspaces": [
    "autogram-sdk",
    "autogram-extension",
    "example-avm-integration",
    "example-extension-usage"
  ],
  "scripts": {
    "dev": "turbo run dev:mv3 dev --filter=autogram-extension --filter=autogram-sdk --filter=example-extension-usage --filter=example-avm-integration",
    "build": "turbo run build",
    "watch:mv2": "turbo run dev:mv2",
    "watch:mv3": "turbo run dev:mv3",
    "example-extension-usage": "turbo run dev --filter=example-extension-usage",
    "example-avm-integration": "turbo run dev --filter=example-avm-integration",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "start": "echo 'Please specify which extension manifest version to start: npm run watch:mv2 or npm run watch:mv3'",
    "build:sdk": "turbo run build --filter=autogram-sdk",
    "build:extension": "turbo run build --filter=autogram-extension",
    "build:dev": "turbo run build:dev --filter=autogram-extension"
  },
  "packageManager": "npm@10.8.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/slovensko-digital/autogram-extension.git"
  },
  "keywords": [
    "autogram",
    "slovensko.digital",
    "slovensko",
    "upvs",
    "slovensko.sk",
    "eidas",
    "eID",
    "electronic",
    "signature",
    "PAdES",
    "XAdE"
  ],
  "author": "pomali",
  "license": "EUPL-1.2",
  "bugs": {
    "url": "https://github.com/slovensko-digital/autogram-extension/issues"
  },
  "homepage": "https://github.com/slovensko-digital/autogram-extension#readme",
  "dependencies": {
    "idb-keyval": "^6.2.1",
    "js-base64": "^3.7.7",
    "loglevel": "^1.9.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.17.12",
    "buffer": "^6.0.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "openapi-typescript": "^6.7.4",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "turbo": "^2.9.3",
    "typescript": "^5.7.3",
    "vite": "^5.2.11"
  }
}
